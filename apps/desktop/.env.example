# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Required ──────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
PYTHON_BIN=/path/to/python3.11

# ── Image search (at least one required for Google Search feature) ──
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
BRAVE_API_KEY=

# ── AI / vision for DB ingestion ──
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Optional: backend server (defaults shown) ──
UFM_PORT=17890
UFM_HOST=127.0.0.1

# ── Optional: Ollama (local vision + embeddings) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=qwen2.5vl
OLLAMA_EMBED_MODEL=nomic-embed-text
UFM_BATCH_DELAY_MS=0

# ── Optional: Firestore ──
FIRESTORE_DATABASE_ID=(default)
# FIRESTORE_EMULATOR_HOST=localhost:8080
